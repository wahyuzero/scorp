# ──────────────────────────────────
# Scorp — Environment Configuration
# Copy to .env and fill in your values.
# Only set the providers you use.
# ──────────────────────────────────

# Telegram (optional — skip for CLI-only mode)
TELEGRAM_BOT_TOKEN=*** ── LLM Providers (set only what you use) ──

# OpenAI
#OPENAI_API_KEY=*** (Claude)
#ANTHROPIC_API_KEY=*** Gemini
#GOOGLE_API_KEY=*** (fast, free tier)
#GROQ_API_KEY=*** Router (gateway to 100+ models)
#OPENROUTER_API_KEY=*** Z.ai (GLM, free tier)
GLM_API_KEY=*** (local — no key needed)
#OLLAMA_HOST=http://localhost:11434

# ── Optional: Coolify Integration ──
#COOLIFY_API_URL=http://localhost:8000
#COOLIFY_API_TOKEN=*** ── Optional: Monitoring Thresholds ──
#CPU_THRESHOLD=90
#RAM_THRESHOLD=85
#DISK_THRESHOLD=85

# ── Optional: Monitoring Toggles ──
#MONITORING_ENABLED=true
#SECURITY_ALERTS_ENABLED=true
#SCHEDULED_REPORTS_ENABLED=false

# ── Optional: Self-Update ──
# Set your GitHub repo to enable update checks (owner/repo format).
# If set, scorp checks for new releases on startup and via /update command.
#GITHUB_REPO=owner/scorp