{
  "default_model": "glm-5.1",
  "agent_model": "glm-5.1",
  "delegation_model": "",
  "premium_model": "glm-agent",
  "models": {
    "glm-5.1": {
      "provider": "zai-coding",
      "model": "glm-5.2",
      "key_env": "GLM_API_KEY",
      "base_url": "https://api.z.ai/api/coding/paas/v4",
      "max_tokens": 4096,
      "api": "openai"
    },
    "glm-agent": {
      "provider": "9router",
      "model": "kr/glm-5-agentic",
      "key_env": "ROUTER_API_KEY",
      "base_url": "http://127.0.0.1:20128/v1",
      "max_tokens": 4096,
      "api": "openai"
    }
  },
  "routing_rules": {
    "agent": "glm-5.1",
    "chat": "glm-5.1"
  },
  "fallback_on_error": [
    "rate_limit",
    "timeout",
    "server_error",
    "auth_error",
    "network_error"
  ]
}